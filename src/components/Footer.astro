---
import JudaicaDHLogo from '../assets/Judaica Digital Humanities Logo 2020_RGB.png'
---

<footer class="w-full bg-white border-t border-slate-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="https://judaicadhpenn.org/"
           class="flex items-center"
           aria-label="Judaica Digital Humanities at Penn">
            <img
                    src={JudaicaDHLogo.src}
                    class="h-8 w-auto"
                    alt="Judaica Digital Humanities Logo"
                    loading="lazy"
                    decoding="async">
        </a>
        <ul class="flex items-center gap-6">
            <li><a href="/" class="text-slate-600 hover:text-slate-900 text-sm">Home</a></li>
            <li><a href="/about" class="text-slate-600 hover:text-slate-900 text-sm">About</a></li>
            <li><a href="/resources" class="text-slate-600 hover:text-slate-900 text-sm">Resources</a></li>
            <li><a href="/contact" class="text-slate-600 hover:text-slate-900 text-sm">Contact</a></li>
        </ul>
    </div>
</footer>