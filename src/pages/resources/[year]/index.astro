---
import { getCollection, getEntry, render } from 'astro:content';
import years from '../../../content/years.json'; // adjust path as needed

import Layout from "../../../layouts/Layout.astro";
import {marked} from "marked";

const { year } = Astro.params;


const yearData = years.find(y => y.year === year);
export async function getStaticPaths() {
    const documents = await getCollection('documents');

    // Extract unique years
    const years = [...new Set(documents.map((doc) => doc.data.year))];

    const paths = years.map((year) => ({
        params: { year: year.toString() },
    }));

    return paths;
}
// Debugging: Fetch and log the documents collection
const documents = (await getCollection('documents')).filter(
    (doc) => doc.data.year === year
);
const tags = [...new Set(documents.flatMap((doc) => doc.data.tags || []))];

---

<Layout>
    <section class="relative isolate py-24 overflow-hidden bg-ink">

    <!-- Background image with the site's aged-print treatment -->
        <div
                class="year-hero-img absolute inset-0 bg-cover bg-center z-[-2]"
                style={`background-image: url(/Year%20images/opt/${year}.webp);`}
        ></div>

        <!-- Warm gradient overlay: lighter at top, darker behind the cards -->
        <div class="absolute inset-0 z-[-1] bg-linear-to-b from-ink/55 via-ink/75 to-ink/90"></div>

        {yearData?.credit && (
                <div class="absolute bottom-4 right-4 bg-paper/85 backdrop-blur-sm text-xs text-ink px-3 py-1 rounded-sm shadow z-10 max-w-xs">
                    Image credit: {yearData.credit}
                </div>
        )}

        <!-- Content -->
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-paper">
            <nav class="text-[0.72rem] uppercase tracking-[0.22em] mb-8" aria-label="Breadcrumb">
                <a href="/resources" class="text-paper/70 hover:text-gilt transition-colors">Resources</a>
                <span class="text-paper/40 mx-1">/</span>
                <span class="text-paper">{year}</span>
            </nav>

            <!-- Title Section -->
            <div class="text-center mb-12">
                <h1 class="font-display text-4xl sm:text-5xl font-semibold text-paper">
                    Resources for {year}
                </h1>
                <div class="mt-4 text-gilt text-lg" aria-hidden="true">&#10086;</div>
            </div>

            <!-- Documents Grid -->
            {documents.length > 0 ? (
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                        {documents.map((doc) => (
                                <a
                                        href={`/resources/${year}/${doc.data.slug}`}
                                        class="group block p-5 sm:p-6 bg-parchment border border-ink/10 rounded-sm shadow-md transition-all hover:shadow-lg hover:border-gilt focus:outline-none focus-visible:ring-2 focus-visible:ring-gilt focus-visible:ring-offset-2 focus-visible:ring-offset-ink"
                                        aria-label={`View document: ${doc.data.title}`}
                                >
                                    <!-- Card Header -->
                                    <h2 class="font-display text-2xl font-semibold mb-3 text-ink group-hover:text-venetian transition-colors"
                                        set:html={marked.parseInline(doc.data.title)} />

                                    <!-- Description -->
                                    <p class="text-ink/70 mb-4 line-clamp-3">
                                        {doc.data.description || "No description available."}
                                    </p>

                                    <!-- Tags as archival labels -->
                                    {doc.data.tags?.length > 0 && (
                                            <div class="flex flex-wrap gap-2">
                                                {doc.data.tags.map((tag) => (
                                                        <span
                                                                class="inline-block border border-ink/15 text-ink/60 text-[0.7rem] uppercase tracking-[0.12em] px-2.5 py-1"
                                                        >
                                                            {tag}
                                                        </span>
                                                ))}
                                            </div>
                                    )}
                                </a>
                        ))}
                    </div>
            ) : (
                    <p class="text-center text-paper/80">
                        No resources available for {year}.
                    </p>
            )}
        </div>
    </section>
</Layout>

<style>
    /* Pull the year photo toward the aged-print look used on the homepage hero */
    .year-hero-img {
        filter: sepia(0.3) saturate(0.85) brightness(0.9);
    }
</style>