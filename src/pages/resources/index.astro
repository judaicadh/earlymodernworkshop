---
import Layout from "../../layouts/Layout.astro";
import yearsData from "../../content/years.json";

// Sort the data by year (descending)
const years = yearsData.sort((a, b) => parseInt(b.year) - parseInt(a.year));
---

<Layout>
    <section class="py-16 sm:py-20 bg-parchment dark:bg-ink transition-colors">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <!-- Heading with the site's eyebrow + fleuron treatment -->
            <div class="text-center mb-10 sm:mb-14 hero-frame">

                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-bronze dark:text-gilt mb-3">
                    The Archive
                </p>
                <h2 class="font-display text-3xl sm:text-4xl font-semibold text-ink dark:text-paper">
                    Resources from Past Workshops
                </h2>
                <div class="mt-4 text-gilt text-lg" aria-hidden="true">&#10086;</div>
            </div>

            {years.length === 0 ? (
                    <p class="text-center text-ink/60 dark:text-paper/60">No resources available.</p>
            ) : (
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
                        {years.map((year) => (
                                <a
                                        href={`/resources/${year.year}`}
                                        class="group block rounded-sm border border-ink/15 dark:border-paper/15 bg-white dark:bg-paper/5 shadow-sm transition-all duration-200 hover:shadow-md hover:border-gilt dark:hover:border-gilt focus:outline-none focus-visible:ring-2 focus-visible:ring-gilt focus-visible:ring-offset-2 focus-visible:ring-offset-parchment dark:focus-visible:ring-offset-ink"
                                        aria-label={`Resources from ${year.year}`}
                                >
                                    <!-- Media -->
                                    <div class="relative overflow-hidden">
                                        {year.thumbnail && (
                                                <img
                                                        src={`/Year images/opt/${year.year}.webp`}
                                                        alt={year.title}
                                                        width="800"
                                                        height="450"
                                                        class="w-full aspect-[16/9] object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                                                        loading="lazy"
                                                        decoding="async"
                                                />
                                        )}
                                        <!-- Year label, set like a printed plate number -->
                                        <span class="absolute top-2 left-2 bg-ink/85 text-paper px-2.5 py-1 text-[0.7rem] font-medium uppercase tracking-[0.18em]">
                                            {year.year}
                                        </span>
                                    </div>

                                    <!-- Body -->
                                    <div class="p-5 sm:p-6">
                                        <h3 class="font-display text-xl sm:text-2xl font-semibold text-ink dark:text-paper mb-2">
                                            {year.title}
                                        </h3>
                                        <p class="text-sm sm:text-base text-ink/70 dark:text-paper/70 line-clamp-3">
                                            {year.description || "No description available."}
                                        </p>

                                        <div class="mt-5">
                                            <span class="inline-flex items-center gap-2 text-[0.78rem] uppercase tracking-[0.18em] text-venetian dark:text-venetian-light">
                                                Browse {year.year} resources
                                                <svg
                                                        class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                        aria-hidden="true"
                                                >
                                                    <path d="M5 12h14" />
                                                    <path d="M13 6l6 6-6 6" />
                                                </svg>
                                            </span>
                                        </div>
                                    </div>
                                </a>
                        ))}
                    </div>
            )}
        </div>
    </section>
</Layout>