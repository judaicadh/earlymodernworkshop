---

import Layout from "../layouts/Layout.astro";
---
<Layout>
    <!-- ========== MAIN CONTENT ========== -->
    <main id="content" class="bg-parchment dark:bg-ink transition-colors">
        <div class="text-center py-20 sm:py-28 px-4 sm:px-6 lg:px-8">
            <p class="text-[0.7rem] uppercase tracking-[0.3em] text-bronze dark:text-gilt mb-3">Page not found</p>
            <h1 class="font-display block text-7xl font-semibold text-ink sm:text-9xl dark:text-paper">404</h1>
            <div class="my-4 text-gilt text-lg" aria-hidden="true">&#10086;</div>
            <p class="mt-2 text-ink/70 dark:text-paper/70">Sorry, we couldn't find the page you were looking for.</p>
            <div class="mt-8 flex flex-col justify-center items-center gap-2 sm:flex-row sm:gap-3">
                <a class="w-full sm:w-auto py-3 px-6 inline-flex justify-center items-center gap-x-2 text-[0.78rem] uppercase tracking-[0.18em] rounded-sm border border-ink/40 dark:border-paper/40 text-ink dark:text-paper hover:bg-venetian hover:border-venetian hover:text-paper focus:outline-none focus-visible:ring-2 focus-visible:ring-gilt transition-colors" href="/">
                    <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                   Return Home
                </a>
            </div>
        </div>
    </main>
    <!-- ========== END MAIN CONTENT ========== -->
</Layout>
