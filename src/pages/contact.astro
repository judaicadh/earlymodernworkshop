---
import Layout from "../layouts/Layout.astro";

---

<Layout>
  <section class="py-16 sm:py-20 bg-parchment dark:bg-ink transition-colors">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-14 hero-frame">

        <h2 class="font-display text-3xl sm:text-4xl font-semibold text-ink dark:text-paper">
       Contact Us
      </h2>
        <div class="mt-4 text-gilt text-lg" aria-hidden="true">&#10086;</div>
      </div>
      <div class="mt-4">
        <p class="mt-6 max-w-3xl mx-auto text-center text-lg text-ink/70 dark:text-paper/70">
        Questions about a source, interested in contributing, or want to learn
        more about the Early Modern Workshop? Send us a message at
        <a href="mailto:emwworkshop@gmail.com" class="text-venetian dark:text-venetian-light underline decoration-gilt/50 underline-offset-4 hover:decoration-gilt focus:outline-none focus-visible:ring-2 focus-visible:ring-gilt">emwworkshop@gmail.com</a>.
      </p>
    </div>
    </div>

  </section>
</Layout>
