---
import Layout from "../layouts/Layout.astro";
---
<Layout>
	<!-- Centered Hero Section -->
	<section class="relative bg-cover bg-center bg-no-repeat py-32 flex items-center justify-center" style="background-image: url('https://primolevicenter.org/printed-matter/wp-content/uploads/2009/03/jews-in-early-modern-venice.jpeg');">
		<div class="absolute inset-0 bg-black bg-opacity-60"></div> <!-- Darker overlay for improved readability -->
		<div class="relative container mx-auto px-4 lg:px-8 flex flex-col items-center text-center text-white">
			<h1 class="text-5xl font-bold mb-6 max-w-4xl">
				Exploring the Early Modern Jewish Experience
			</h1>
			<p class="text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
				A collaborative hub for scholarship, innovation, and resources on Jewish life in the Early Modern period.
			</p>
			<a href="/resources" class="bg-indigo-600 text-white px-8 py-3 rounded-md shadow-lg hover:bg-indigo-700 transition">
				Browse Resources
			</a>
		</div>
	</section>
</Layout>

