---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<!-- Fonts: ideally move these two lines into Layout.astro's <head> -->
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link
		href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,500;0,600;1,400&display=swap"
		rel="stylesheet"
	/>

	<section class="hero relative flex items-center justify-center overflow-hidden">
		<!-- Image with a warm duotone treatment instead of a flat black scrim -->
		<div class="absolute inset-0" aria-hidden="true">
			<img
				src="https://primolevicenter.org/printed-matter/wp-content/uploads/2009/03/jews-in-early-modern-venice.jpeg"
				alt=""
				class="hero-img h-full w-full object-cover"
			/>
			<div class="hero-tint absolute inset-0"></div>
			<div class="hero-vignette absolute inset-0"></div>
		</div>

		<!-- Content framed like a printed title page -->
		<div
			class="hero-frame relative mx-4 my-20 w-full max-w-3xl px-6 py-12 text-center sm:px-14 sm:py-16"
		>
			<p class="eyebrow">The Early Modern Workshop</p>

			<h1 class="display">
				Exploring the Early Modern<br class="hidden sm:block" /> Jewish
				Experience
			</h1>

			<div class="fleuron" aria-hidden="true">&#10086;</div>

			<p class="subhead mx-auto max-w-xl">
				A collaborative hub for scholarship, innovation, and resources on
				Jewish life in the Early Modern period.
			</p>

			<a href="/resources" class="cta">Browse Resources</a>
		</div>
	</section>
</Layout>

<style>
	/* Palette: aged ink #1b130d · warm paper #f4ecda · gilt #cfa45c · Venetian red #8e2f23 */

	.hero {
		min-height: 88vh;
		background-color: #1b130d;
	}

	/* Pull the photo toward an aged-print look */
	.hero-img {
		filter: sepia(0.35) saturate(0.8) contrast(1.05) brightness(0.9);
	}
	.hero-tint {
		background-color: #2b1a10;
		mix-blend-mode: multiply;
		opacity: 0.5;
	}
	.hero-vignette {
		background: radial-gradient(
			ellipse at center,
			rgba(18, 12, 7, 0.15) 0%,
			rgba(18, 12, 7, 0.8) 100%
		);
	}

	/* Double hairline rule, like the border of an early modern title page */
	.hero-frame {
		border: 1px solid rgba(241, 230, 207, 0.55);
		background: rgba(18, 12, 7, 0.35);
	}
	.hero-frame::before {
		content: "";
		position: absolute;
		inset: 7px;
		border: 1px solid rgba(241, 230, 207, 0.28);
		pointer-events: none;
	}

	.eyebrow {
		font-size: 0.72rem;
		letter-spacing: 0.32em;
		text-transform: uppercase;
		color: #cfa45c;
		margin-bottom: 1.5rem;
	}

	.display {
		font-family: "EB Garamond", Georgia, serif;
		font-weight: 600;
		font-size: clamp(2.4rem, 6vw, 4.25rem);
		line-height: 1.08;
		color: #f4ecda;
		text-wrap: balance;
	}

	.fleuron {
		color: #cfa45c;
		font-size: 1.35rem;
		margin: 1.25rem 0;
	}

	.subhead {
		font-family: "EB Garamond", Georgia, serif;
		font-style: italic;
		font-size: 1.3rem;
		line-height: 1.6;
		color: rgba(244, 236, 218, 0.85);
		margin-bottom: 2.5rem;
	}

	.cta {
		display: inline-block;
		font-size: 0.78rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #f4ecda;
		border: 1px solid rgba(241, 230, 207, 0.7);
		padding: 0.9rem 2.4rem;
		transition:
			background-color 180ms ease,
			border-color 180ms ease;
	}
	.cta:hover {
		background-color: #8e2f23;
		border-color: #8e2f23;
	}
	.cta:focus-visible {
		outline: 2px solid #cfa45c;
		outline-offset: 3px;
	}

	/* Quiet staggered entrance; respects reduced-motion */
	@media (prefers-reduced-motion: no-preference) {
		.hero-frame > * {
			animation: rise 700ms ease both;
		}
		.hero-frame > *:nth-child(2) {
			animation-delay: 90ms;
		}
		.hero-frame > *:nth-child(3) {
			animation-delay: 180ms;
		}
		.hero-frame > *:nth-child(4) {
			animation-delay: 270ms;
		}
		.hero-frame > *:nth-child(5) {
			animation-delay: 360ms;
		}
		@keyframes rise {
			from {
				opacity: 0;
				transform: translateY(10px);
			}
			to {
				opacity: 1;
				transform: none;
			}
		}
	}
</style>