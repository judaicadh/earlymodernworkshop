---
import Footer from "../components/Footer.astro";
import Head from "../components/Head.astro";
import Nav from "../components/Nav.astro";
import "astro-breadcrumbs/breadcrumbs.css";
import "../styles/global.css";

---

<!doctype html>
<html lang="en">
<Head><slot name="head" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link
		href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Frank+Ruhl+Libre:wght@400;500;700&display=swap"
		rel="stylesheet"
	/></Head>
<body class="font-serif min-h-screen flex flex-col">

<!-- Navigation Bar -->
<Nav />

<!-- Breadcrumb Navigation -->
<div class="container mx-auto px-4">
	<!-- Add breadcrumbs here if needed -->
</div>

<!-- Main Content -->
<div class="flex-1">
	<slot />
</div>

<!-- Footer Section -->
<Footer />
</body>
</html>

<style>
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
	}
</style>